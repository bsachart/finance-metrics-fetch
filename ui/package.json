{
  "name": "finance-metrics-fetch-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-data": "node scripts/copy-data.mjs",
    "dev": "npm run sync-data && vite dev",
