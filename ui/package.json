    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "jsdom": "^29.0.1",
    "lightweight-charts": "^5.1.0",
    "papaparse": "^5.5.3",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
